pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                echo "Triggering release notesr"
            }
        }
    }
    post {
        success {
            build job: 'release-notes',
                wait: false,
                parameters: [
                    string(name: 'REPO_NAME', value: 'MarfeelSDK-ReactNative'),
                    string(name: 'COMMIT_HASH', value: env.GIT_COMMIT)
                ]
        }
    }
}